# GitHub OAuth Configuration
# This is a DEFAULT file - replace with your actual values
# Copy to .env and fill in your real Client ID
#
# To get your GitHub OAuth Client ID:
# 1. Go to https://github.com/settings/developers
# 2. Create a new OAuth App
# 3. Copy your Client ID
# 4. Replace 'your_client_id_here' below

GITHUB_CLIENT_ID=your_client_id_here
